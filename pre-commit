#!/usr/bin/env bash
# .git/hooks/pre-commit
# Corre antes de cada commit del usuario.
# Instalado por /git-setup

set -e

echo "рџ”Ќ pre-commit: verificando cambios..."

# в”Ђв”Ђв”Ђ Archivos a revisar en este commit в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "вњ“ Sin archivos staged para revisar."
  exit 0
fi

EXIT_CODE=0

# в”Ђв”Ђв”Ђ 1. Archivos prohibidos в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

echo "  Verificando archivos prohibidos..."

FORBIDDEN_PATTERNS=(
  "\.env$"
  "\.env\.local$"
  "\.env\.production$"
  "\.env\.staging$"
  "node_modules/"
  "\.tsbuildinfo$"
  "\.db$"
  "\.sqlite$"
  "\.sqlite3$"
  "dist/"
  "build/"
  "\.DS_Store$"
  "Thumbs\.db$"
  "\.pem$"
  "\.key$"
  "\.p12$"
)

for file in $STAGED_FILES; do
  for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if echo "$file" | grep -qE "$pattern"; then
      echo "  вќЊ Archivo prohibido en commit: $file"
      echo "     PatrГіn: $pattern"
      echo "     Agrega este archivo a .gitignore y quГ­talo del staging:"
      echo "     git rm --cached $file"
      EXIT_CODE=1
    fi
  done
done

if [ $EXIT_CODE -ne 0 ]; then
  exit $EXIT_CODE
fi

echo "  вњ“ Sin archivos prohibidos."

# в”Ђв”Ђв”Ђ 2. Detectar stack в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

HAS_NODE=$([ -f "package.json" ] && echo "yes")
HAS_PYTHON=$([ -f "pyproject.toml" ] || [ -f "setup.py" ] && echo "yes")
HAS_BIOME=$([ -f "node_modules/.bin/biome" ] && echo "yes")
HAS_ESLINT=$([ -f "node_modules/.bin/eslint" ] && echo "yes")
HAS_RUFF=$(command -v ruff 2>/dev/null && echo "yes")

# в”Ђв”Ђв”Ђ 3. Lint de JS/TS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

JS_FILES=$(echo "$STAGED_FILES" | grep -E "\.(js|jsx|ts|tsx|mjs)$" || true)

if [ -n "$JS_FILES" ] && [ "$HAS_NODE" = "yes" ]; then
  echo "  Lint JS/TS..."

  if [ "$HAS_BIOME" = "yes" ]; then
    echo "$JS_FILES" | xargs node_modules/.bin/biome check --no-errors-on-unmatched 2>/dev/null
    LINT_CODE=$?
  elif [ "$HAS_ESLINT" = "yes" ]; then
    echo "$JS_FILES" | xargs node_modules/.bin/eslint --max-warnings=0 2>/dev/null
    LINT_CODE=$?
  else
    echo "  вљ пёЏ  Sin linter JS/TS instalado (biome o eslint). Saltando lint."
    LINT_CODE=0
  fi

  if [ $LINT_CODE -ne 0 ]; then
    echo "  вќЊ Lint fallГі. Corrige los errores antes de commitear."
    echo "     Ejecuta: npm run lint"
    EXIT_CODE=$LINT_CODE
  else
    echo "  вњ“ Lint JS/TS OK."
  fi
fi

# в”Ђв”Ђв”Ђ 4. TypeScript type-check в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

TS_FILES=$(echo "$STAGED_FILES" | grep -E "\.(ts|tsx)$" || true)

if [ -n "$TS_FILES" ] && [ "$HAS_NODE" = "yes" ] && [ -f "tsconfig.json" ]; then
  if [ -f "node_modules/.bin/tsc" ]; then
    echo "  Type-check TypeScript..."
    node_modules/.bin/tsc --noEmit --skipLibCheck 2>/dev/null
    TSC_CODE=$?
    if [ $TSC_CODE -ne 0 ]; then
      echo "  вќЊ TypeScript: errores de tipo encontrados."
      echo "     Ejecuta: npm run typecheck"
      EXIT_CODE=$TSC_CODE
    else
      echo "  вњ“ TypeScript OK."
    fi
  else
    echo "  вљ пёЏ  tsc no encontrado en node_modules. Saltando type-check."
  fi
fi

# в”Ђв”Ђв”Ђ 5. Lint Python в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

PY_FILES=$(echo "$STAGED_FILES" | grep -E "\.py$" || true)

if [ -n "$PY_FILES" ] && [ "$HAS_RUFF" = "yes" ]; then
  echo "  Lint Python (ruff)..."
  echo "$PY_FILES" | xargs ruff check 2>/dev/null
  RUFF_CODE=$?
  if [ $RUFF_CODE -ne 0 ]; then
    echo "  вќЊ ruff fallГі. Ejecuta: ruff check --fix"
    EXIT_CODE=$RUFF_CODE
  else
    echo "  вњ“ Python OK."
  fi
fi

# в”Ђв”Ђв”Ђ Resultado final в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if [ $EXIT_CODE -eq 0 ]; then
  echo "вњ… pre-commit: todo OK. Procediendo con el commit."
else
  echo ""
  echo "вќЊ pre-commit fallГі. Corrige los errores antes de commitear."
  echo "   Para saltarte el hook excepcionalmente (no recomendado):"
  echo "   git commit --no-verify -m \"tu mensaje\""
fi

exit $EXIT_CODE
