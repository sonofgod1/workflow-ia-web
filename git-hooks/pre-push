#!/usr/bin/env bash
# .git/hooks/pre-push — v1.1
# fix: set -e removido; detección de stack tolerante a fallo

REMOTE="$1"
URL="$2"

echo "🚀 pre-push: verificando antes de push a $REMOTE ($URL)..."

EXIT_CODE=0

HAS_NODE=""
HAS_PYTHON=""
[ -f "package.json" ] && HAS_NODE="yes"
[ -f "pyproject.toml" ] && HAS_PYTHON="yes"
[ -f "setup.py" ] && HAS_PYTHON="yes"

echo "  Ejecutando tests..."

if [ "$HAS_NODE" = "yes" ]; then
  if grep -q '"test"' package.json 2>/dev/null; then
    npm test --silent 2>/dev/null
    TEST_CODE=$?
    if [ $TEST_CODE -ne 0 ]; then
      echo "  ❌ Tests fallaron. Ejecuta: npm test"
      EXIT_CODE=$TEST_CODE
    else
      echo "  ✓ Tests JS/TS OK."
    fi
  else
    echo "  ⚠️  Sin script 'test' en package.json. Saltando tests."
  fi
elif [ "$HAS_PYTHON" = "yes" ]; then
  if command -v pytest > /dev/null 2>&1; then
    pytest --tb=short -q 2>/dev/null
    TEST_CODE=$?
    [ $TEST_CODE -ne 0 ] && echo "  ❌ Tests Python fallaron." && EXIT_CODE=$TEST_CODE || echo "  ✓ Tests Python OK."
  else
    echo "  ⚠️  pytest no encontrado. Saltando tests Python."
  fi
else
  echo "  ⚠️  Stack no detectado. Saltando tests."
fi

if [ -f "docs/contracts/components.ts" ] && [ -f "node_modules/.bin/tsc" ]; then
  node_modules/.bin/tsc --noEmit --strict --skipLibCheck 2>/dev/null
  CONTRACTS_CODE=$?
  [ $CONTRACTS_CODE -ne 0 ] && echo "  ❌ Contratos TypeScript inválidos." && EXIT_CODE=$CONTRACTS_CODE || echo "  ✓ Contratos TypeScript OK."
fi

CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || true)
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
  echo ""
  echo "  ⚠️  Push directo a main. Flujo recomendado: feature/* → develop → main"
  echo "     Si es release o hotfix intencional, continúa."
  echo ""
fi

[ $EXIT_CODE -eq 0 ] && echo "✅ pre-push: OK." || echo "❌ pre-push falló. Para saltarte: git push --no-verify"
exit $EXIT_CODE
